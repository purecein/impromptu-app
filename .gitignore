# ============================================================
# Xcode
# ============================================================

# 빌드 결과물
build/
DerivedData/

# 사용자별 Xcode 설정 (xcuserdata)
# xcuserdata/ 단일 패턴으로 중첩 경로 (.xcodeproj/project.xcworkspace/xcuserdata/ 등) 전체 제외
xcuserdata/

# Xcode 자동 생성 scheme (공유 scheme은 커밋 가능)
*.xcodeproj/xcshareddata/xcschemes/

# Playground
*.xcplayground/

# Xcode Previews
PreviewContent/

# ============================================================
# Swift Package Manager
# ============================================================

.build/
.swiftpm/
*.resolved          # Package.resolved는 앱 타깃이면 커밋 권장, 라이브러리면 무시

# ============================================================
# CocoaPods (미사용이어도 방어적으로)
# ============================================================

Pods/
Podfile.lock

# ============================================================
# macOS 시스템
# ============================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
*.swp
*.swo
*~

# ============================================================
# 에디터 / IDE
# ============================================================

# VSCode
.vscode/

# JetBrains
.idea/

# ============================================================
# 코드 서명 / 배포
# ============================================================

# 로컬 Team ID 설정 파일 (커밋 금지 — Local.xcconfig.template 참고)
Local.xcconfig

*.cer
*.p12
*.mobileprovision
*.provisionprofile
ExportOptions.plist

# ============================================================
# 기타
# ============================================================

# 환경 변수 파일
.env
.env.local

# 테스트 커버리지
*.xcresult/
